#!/bin/bash
# Auto-bump patch version on every commit.
# Reads current version from plugin.json, increments patch, updates all version fields.

PLUGIN_JSON="plugins/vibeloupe/.claude-plugin/plugin.json"
SKILLS=(
  "plugins/vibeloupe/skills/hypothesis-validator/SKILL.md"
  "plugins/vibeloupe/skills/learn-loop/SKILL.md"
  "plugins/vibeloupe/skills/spec-review/SKILL.md"
  "plugins/vibeloupe/skills/sprint-recap/SKILL.md"
)

# Read current version
CURRENT=$(grep '"version"' "$PLUGIN_JSON" | sed 's/.*"version": "\(.*\)".*/\1/')

# Split and increment patch
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
NEW_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"

# Update plugin.json
sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PLUGIN_JSON"

# Update all SKILL.md frontmatter
for SKILL in "${SKILLS[@]}"; do
  sed -i '' "s/^version: .*/version: $NEW_VERSION/" "$SKILL"
done

# Stage the bumped files so they're included in this commit
git add "$PLUGIN_JSON" "${SKILLS[@]}"

echo "↑ vibeloupe $CURRENT → $NEW_VERSION"
